<?xml version="1.0" encoding="utf-8"?>
<!-- HIDL/AIDL Device Manifest for Ayaneo Pocket DS (SM8750) -->
<!-- NOTE: HAL versions are best-guess for SM8750 (Android 14).
     Verify against stock: adb shell cat /vendor/etc/vintf/manifest.xml -->
<manifest version="1.0" type="device">

    <!-- Audio — SM8750 uses AIDL audio HAL (PAL / libaudiocorehal.qti).
         HIDL audio@7.x is not used on SM8750; removing it prevents VINTF compliance
         failures. The service binary ships in vendor via extract-blobs.sh. -->
    <hal format="aidl">
        <name>android.hardware.audio.core</name>
        <version>1</version>
        <fqname>IModule/default</fqname>
        <fqname>IModule/r_submix</fqname>
        <fqname>IModule/usb</fqname>
        <!-- NOTE: IModule/stub is AOSP test-only, not a QTI instance. Remove after
             verifying actual instances from: adb shell cat /vendor/etc/vintf/manifest.xml -->
    </hal>
    <hal format="aidl">
        <name>android.hardware.audio.effect</name>
        <version>1</version>
        <fqname>IFactory/default</fqname>
    </hal>

    <!-- Graphics — SM8750 uses Composer3 (AIDL) and AIDL gralloc allocator v2.
         device.mk builds android.hardware.graphics.mapper@4.0-impl-qti-display
         (HIDL mapper 4.0). Android 14 supports HIDL mapper@4.0 alongside AIDL
         allocator v2 as a transitional "multi-generation gralloc" path. -->
    <hal format="aidl">
        <name>android.hardware.graphics.composer3</name>
        <version>1</version>
        <fqname>IComposer/default</fqname>
    </hal>
    <hal format="aidl">
        <name>android.hardware.graphics.allocator</name>
        <version>2</version>
        <fqname>IAllocator/default</fqname>
    </hal>

    <!-- Bluetooth -->
    <hal format="aidl">
        <name>android.hardware.bluetooth</name>
        <version>1</version>
        <fqname>IBluetoothHci/default</fqname>
    </hal>
    <!-- Bluetooth Audio — SM8750 uses AIDL (HIDL 2.1 was deprecated in Android 14).
         Version 2 matches QTI "sun" platform. Verify against stock manifest. -->
    <hal format="aidl">
        <name>android.hardware.bluetooth.audio</name>
        <version>2</version>
        <fqname>IBluetoothAudioProviderFactory/default</fqname>
    </hal>

    <!-- DRM -->
    <hal format="aidl">
        <name>android.hardware.drm</name>
        <version>1</version>
        <fqname>IDrmFactory/widevine</fqname>
        <fqname>IDrmFactory/clearkey</fqname>
    </hal>

    <!-- Health -->
    <hal format="aidl">
        <name>android.hardware.health</name>
        <version>1</version>
        <fqname>IHealth/default</fqname>
    </hal>

    <!-- Keymint (replaces keymaster on SM8750) -->
    <hal format="aidl">
        <name>android.hardware.security.keymint</name>
        <version>3</version>
        <fqname>IKeyMintDevice/default</fqname>
    </hal>

    <!-- Power -->
    <hal format="aidl">
        <name>android.hardware.power</name>
        <version>4</version>
        <fqname>IPower/default</fqname>
    </hal>

    <!-- Sensors -->
    <hal format="aidl">
        <name>android.hardware.sensors</name>
        <version>2</version>
        <fqname>ISensors/default</fqname>
    </hal>

    <!-- Thermal -->
    <hal format="aidl">
        <name>android.hardware.thermal</name>
        <version>1</version>
        <fqname>IThermal/default</fqname>
    </hal>

    <!-- USB -->
    <hal format="aidl">
        <name>android.hardware.usb</name>
        <version>1</version>
        <fqname>IUsb/default</fqname>
    </hal>

    <!-- Vibrator -->
    <hal format="aidl">
        <name>android.hardware.vibrator</name>
        <version>2</version>
        <fqname>IVibrator/default</fqname>
    </hal>

    <!-- Wi-Fi -->
    <hal format="hidl">
        <name>android.hardware.wifi</name>
        <transport>hwbinder</transport>
        <version>1.6</version>
        <interface>
            <name>IWifi</name>
            <instance>default</instance>
        </interface>
    </hal>

    <!-- Camera (TODO: verify version from stock) -->
    <hal format="aidl">
        <name>android.hardware.camera.provider</name>
        <version>2</version>
        <fqname>ICameraProvider/internal/0</fqname>
    </hal>

    <!-- Gatekeeper -->
    <hal format="aidl">
        <name>android.hardware.gatekeeper</name>
        <version>1</version>
        <fqname>IGatekeeper/default</fqname>
    </hal>

    <!-- Boot -->
    <hal format="aidl">
        <name>android.hardware.boot</name>
        <version>1</version>
        <fqname>IBootControl/default</fqname>
    </hal>

    <!-- Lights — AIDL HAL (android.hardware.light is AIDL on Android 13+) -->
    <hal format="aidl">
        <name>android.hardware.light</name>
        <version>2</version>
        <fqname>ILights/default</fqname>
    </hal>

</manifest>
